# ═══════════════════════════════════════════════
# DevForge — Environment Variables Reference
# ═══════════════════════════════════════════════
# Copy this file and fill in real values.
# NEVER commit the filled-in version to Git.
#
# For Kubernetes deployment, these values go into
# k8s/secrets.yml (see k8s/secrets.yml.example).
# ═══════════════════════════════════════════════


# ─── Auth Service ────────────────────────────
# MongoDB connection string for the auth database
AUTH_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/auth

# Google OAuth 2.0 credentials (console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# RabbitMQ connection (CloudAMQP or self-hosted)
RABBITMQ_URL=amqps://<user>:<password>@<host>/<vhost>


# ─── Sandbox Server ─────────────────────────
# MongoDB connection for sandbox/project database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sandbox

# Redis connection for sandbox TTL tracking
REDIS_URL=redis://default:<password>@<host>:<port>

# Container images used when provisioning sandbox pods
# (short names for local/minikube, full ECR URIs for EKS)
TEMPLATE_IMAGE=template
AGENT_IMAGE=agent
SYNC_AGENT_IMAGE=sync-agent


# ─── AI Orchestration ───────────────────────
# Mistral AI API key (console.mistral.ai)
MISTRALAI_API_KEY=


# ─── Notification Service ───────────────────
# Gmail OAuth2 credentials for sending login notification emails
EMAIL_USER=you@gmail.com
GOOGLE_REFRESH_TOKEN=

# RabbitMQ (same URL as auth service)
# RABBITMQ_URL=  (already defined above)


# ─── Sync Agent (Optional — S3 Persistence) ─
# Only needed if you want sandbox files to persist across restarts
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ─── Router ─────────────────────────────────
# Redis (same URL as sandbox server)
# REDIS_URL=  (already defined above)
